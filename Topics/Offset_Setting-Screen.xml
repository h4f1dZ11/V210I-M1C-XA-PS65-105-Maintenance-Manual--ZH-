<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="../helpproject.xsl" ?>
<topic template="Default" modified="2026-03-05T12:05:45.575Z" lasteditedby="noorhbo" version="2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../helpproject.xsd">
  <title>偏移/设置屏幕</title>
  <body>
    <header>
      <para styleclass="Heading3">偏移/设置屏幕</para>
    </header>
    <para styleclass="Normal"><text styleclass="" style="font-family:SimSun; font-size:11pt; color:#000000;">按 MDI 面板上的</text><text styleclass="" style="font-family:SimSun; font-size:11pt; font-weight:bold; color:#000000;">[偏移]</text><text styleclass="" style="font-family:SimSun; font-size:11pt; color:#000000;"> 键可在偏置/设置屏幕上显示下列屏幕。可在此屏幕上显示或设置刀具补偿值和数据。各屏幕的选择按钮（软键）说明如下。</text></para>
    <para styleclass="Normal"></para>
    <para styleclass="Normal" style="text-align:center; margin-bottom:10px;"><image src="2.2 Offset Setting Screen_1.png" scale="45.00%" width="397" height="189" styleclass="Image Caption" figurelistinclude="0"></image></para>
    <para styleclass="" style="text-align:left; text-indent:0px; margin-top:0px; margin-right:0px; margin-bottom:0px; margin-left:0px; line-height:1.00; background-color:transparent; white-space:normal; page-break-inside:auto; page-break-after:auto; border:none; tabstops:none;"><text styleclass="" style="font-family:SimSun; font-size:11pt; color:#000000;">带</text><text styleclass="" style="font-family:Arial; font-size:11pt; color:#000000;"> (*) </text><text styleclass="" style="font-family:SimSun; font-size:11pt; color:#000000;">的按钮可能显示，也可能不显示，具体取决于机床规格。</text></para>
    <para styleclass="" style="text-align:left; text-indent:0px; margin-top:0px; margin-right:0px; margin-bottom:0px; margin-left:0px; line-height:1.00; background-color:transparent; white-space:normal; page-break-before:always; page-break-inside:auto; page-break-after:auto; border:none; tabstops:none;"></para>
    <para styleclass="Normal"><table styleclass="Default" rowcount="12" colcount="3" style="border-width:0px; border-spacing:0px; border-collapse:collapse; cell-border-width:1px; border-color:#000000; border-style:solid; head-row-background-color:#c0c0c0; alt-row-background-color:none;">
      <thead style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">编号</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">按钮</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">说明</para>
        </td>
      </thead>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">1</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">偏移</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择屏幕工具偏移值。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">2</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">设置</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置参数的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">3</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">工作</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置工件坐标系偏置的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">6</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">宏观</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置宏变量的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">8</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">操作面板</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择将主操作面板上的某些操作开关作为 MDI 面板上的软键进行操作的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">9</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">工具管理器 (*)</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置刀具管理相关数据的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">12</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">PR-LV (*)</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置精度等级的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">17</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">语言</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置显示语言的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">18</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">保护</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置数据保护的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">19</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">保护</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">选择用于设置防止错误操作的屏幕。</text></para>
        </td>
      </tr>
      <tr style="vertical-align:middle">
        <td style="width:10%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">5,10,15,20</para>
        </td>
        <td style="width:25%; height:25px;">
          <para styleclass="Normal" style="text-align:center;">(OPRT)</para>
        </td>
        <td style="width:60%; height:25px;">
          <para styleclass="Normal" style="margin-right:2px; margin-left:2px;"><text styleclass="" style="font-family:Arial; font-size:10pt; color:#000000;">操作选择按键。</text></para>
        </td>
      </tr>
    </table></para>
    <para styleclass="Normal"></para>
    <para styleclass="Normal"></para>
    <para styleclass="Normal"><text styleclass="" style="font-family:SimSun; font-size:11pt; color:#000000;">按 </text><text styleclass="" style="font-family:SimSun; font-size:12pt; font-weight:bold; color:#000000;">[偏移]</text><text styleclass="" style="font-family:SimSun; font-size:12pt; color:#000000;"> 键后</text><text styleclass="" style="font-family:SimSun; font-size:11pt; color:#000000;">的转换顺序</text><text styleclass="" style="font-family:SimSun; font-size:12pt; color:#000000;">如下所示。</text></para>
    <para styleclass="Normal"></para>
    <para styleclass="" style="text-align:center; text-indent:0px; margin-top:0px; margin-right:0px; margin-bottom:0px; margin-left:0px; line-height:1.00; background-color:transparent; white-space:normal; page-break-inside:auto; page-break-after:auto; border:none; tabstops:none;"><image src="2.2 Offset Setting Screen_2.png" scale="60.00%" width="521" height="218" styleclass="Image Caption" figurelistinclude="0"></image></para>
    <para styleclass="" style="text-align:center; text-indent:0px; margin-top:0px; margin-right:0px; margin-bottom:8px; margin-left:0px; line-height:1.00; background-color:transparent; white-space:normal; page-break-before:always; page-break-inside:auto; page-break-after:auto; border:none; tabstops:none;"></para>
  </body>
</topic>
